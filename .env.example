# Copy to .env and fill in. Generate a strong random string for LTI_ENCRYPTION_KEY.

PORT=3001
NODE_ENV=development

# Required: used to encrypt DB rows and sign cookies (min ~16 chars)
LTI_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# MongoDB: use "memory" for quick local runs (no Docker), or e.g. mongodb://127.0.0.1:27017/ltijs_canvas_demo with docker compose up -d
MONGODB_URI=memory

# Canvas LTI 1.3 — from Admin → Developer Keys → your key
# CANVAS_PLATFORM_URL must match the JWT "iss" from Canvas (your Canvas base URL, no trailing slash).
# Examples: https://canvas.instructure.com  OR  https://yourschool.instructure.com
CANVAS_PLATFORM_URL=https://canvas.instructure.com
CANVAS_CLIENT_ID=

# Optional label stored in ltijs
# CANVAS_PLATFORM_NAME=Canvas

# LTI_DEV_MODE=true skips strict cookie checks (useful for http://localhost testing).
# For https + ngrok against production Canvas, set NODE_ENV=production and LTI_DEV_MODE=false.
